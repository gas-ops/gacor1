<style>
.rain-container{
    position:fixed;
    inset:0;
    width:100%;
    height:100%;
    pointer-events:none;
    z-index:9999;
    overflow:hidden;
}

.rain{
    position:absolute;
    width:2px;
    height:120px;
    background:linear-gradient(
        transparent,
        rgba(255,255,255,.9)
    );
    animation:rainFall linear infinite;
}

@keyframes rainFall{
    from{
        transform:translateY(-150px);
    }
    to{
        transform:translateY(calc(100vh + 150px));
    }
}

.lightning{
    position:fixed;
    inset:0;
    background:#ffffff;
    opacity:0;
    pointer-events:none;
    z-index:9998;
    animation:lightningFlash 7s infinite;
}

@keyframes lightningFlash{
    0%,90%,100%{
        opacity:0;
    }

    91%{
        opacity:.8;
    }

    91.3%{
        opacity:0;
    }

    91.6%{
        opacity:1;
    }

    92%{
        opacity:0;
    }

    92.3%{
        opacity:.6;
    }

    93%{
        opacity:0;
    }
}

.lightning-bolt{
    position:fixed;
    top:-100px;
    left:50%;
    width:8px;
    height:500px;
    background:white;
    transform:translateX(-50%) rotate(15deg);
    filter:
        drop-shadow(0 0 10px #fff)
        drop-shadow(0 0 20px #fff)
        drop-shadow(0 0 40px #fff);
    opacity:0;
    z-index:9999;
    pointer-events:none;
    animation:boltStrike 7s infinite;
}

.lightning-bolt::before,
.lightning-bolt::after{
    content:"";
    position:absolute;
    background:white;
}

.lightning-bolt::before{
    width:8px;
    height:220px;
    left:-40px;
    top:130px;
    transform:rotate(-35deg);
}

.lightning-bolt::after{
    width:8px;
    height:180px;
    left:30px;
    top:260px;
    transform:rotate(35deg);
}

@keyframes boltStrike{
    0%,90%,100%{
        opacity:0;
    }

    91%{
        opacity:1;
    }

    92%{
        opacity:0;
    }

    92.3%{
        opacity:1;
    }

    93%{
        opacity:0;
    }
}
</style>

